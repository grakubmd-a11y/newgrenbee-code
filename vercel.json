{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/process-recurring-plans",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/process-abandoned-leads",
      "schedule": "*/30 * * * *"
    }
  ]
}
