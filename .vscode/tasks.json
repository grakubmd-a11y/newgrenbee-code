{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Git: Commit & Push",
      "type": "shell",
      "command": "git add -A && git commit -m \"${input:commitMessage}\" && git push",
      "group": "none",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "panel": "shared",
        "showReuseMessage": false
      },
      "problemMatcher": []
    },
    {
      "label": "Deploy: Build & Firebase",
      "type": "shell",
      "command": "npm run build && firebase deploy",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "panel": "shared",
        "showReuseMessage": false
      },
      "problemMatcher": []
    },
    {
      "label": "Deploy: Build & Firebase Hosting Only",
      "type": "shell",
      "command": "npm run build && firebase deploy --only hosting",
      "group": "none",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "panel": "shared",
        "showReuseMessage": false
      },
      "problemMatcher": []
    },
    {
      "label": "Commit + Build + Deploy (Full)",
      "dependsOrder": "sequence",
      "dependsOn": [
        "Git: Commit & Push",
        "Deploy: Build & Firebase"
      ],
      "group": "none",
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "commitMessage",
      "type": "promptString",
      "description": "Mensaje del commit",
      "default": "Update"
    }
  ]
}
