# ─────────────────────────────────────────────────────────────────────────────
# grenbee-firebase-web — Environment Variables
# Copy this file to .env.local for local development (never commit .env.local).
# All VITE_* vars are bundled into the browser build.
# All other vars are server-only (Vercel Functions / Node).
# ─────────────────────────────────────────────────────────────────────────────

# ── Stripe ────────────────────────────────────────────────────────────────────
# Browser-safe publishable key (use pk_test_... for dev, pk_live_... for prod)
VITE_STRIPE_PUBLISHABLE_KEY="pk_test_REPLACE_ME"

# Secret key — server only, NEVER expose to the browser
STRIPE_SECRET_KEY="sk_test_REPLACE_ME"

# Webhook signing secret — obtained from Stripe Dashboard → Webhooks
# Used by api/stripe-webhook.js to verify event signatures
STRIPE_WEBHOOK_SECRET="whsec_REPLACE_ME"

# ── Firebase Client SDK (browser) ─────────────────────────────────────────────
# These are already embedded in firebase-applet-config.json for the AI Studio
# environment. In a standard Firebase project, set them here and update
# src/shared/firebase.ts to read from import.meta.env instead.
#
# VITE_FIREBASE_API_KEY="AIza..."
# VITE_FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
# VITE_FIREBASE_PROJECT_ID="your-project"
# VITE_FIREBASE_STORAGE_BUCKET="your-project.firebasestorage.app"
# VITE_FIREBASE_MESSAGING_SENDER_ID="123456789"
# VITE_FIREBASE_APP_ID="1:123456789:web:abc123"
# VITE_FIREBASE_DATABASE_ID="(default)"   # Only needed for named databases

# ── Firebase Admin SDK (server / Vercel Functions) ────────────────────────────
# Full service-account JSON as a single env var (paste the file content here).
# Download from Firebase Console → Project Settings → Service Accounts.
# In Vercel: paste into Environment Variable "FIREBASE_SERVICE_ACCOUNT_JSON".
FIREBASE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"REPLACE_ME","private_key_id":"REPLACE_ME","private_key":"-----BEGIN PRIVATE KEY-----\nREPLACE_ME\n-----END PRIVATE KEY-----\n","client_email":"firebase-adminsdk@REPLACE_ME.iam.gserviceaccount.com","client_id":"REPLACE_ME","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}'

# ── Resend (transactional email) ──────────────────────────────────────────────
# Get your key at https://resend.com/api-keys
RESEND_API_KEY="re_REPLACE_ME"

# From address for all outgoing emails (must be a verified domain in Resend)
NOTIFY_FROM="Greenbee <hello@grenbee.com>"

# ── Google Maps ───────────────────────────────────────────────────────────────
# Browser key — restrict by HTTP referrer in Google Cloud Console
VITE_GOOGLE_MAPS_API_KEY="AIza_REPLACE_ME_BROWSER_KEY"

# Server key — used by api/ functions for server-side geocoding (optional)
# Restrict by IP or leave unrestricted if only used server-side
GOOGLE_MAPS_API_KEY="AIza_REPLACE_ME_SERVER_KEY"

# ── Cron security ─────────────────────────────────────────────────────────────
# Random secret added to Vercel cron requests as x-cron-secret header.
# Set this in Vercel Dashboard → Environment Variables.
# All api/process-*.js handlers validate this header.
# Generate with: openssl rand -hex 32
CRON_SECRET="REPLACE_ME_32_HEX_CHARS"

# ── App URL ───────────────────────────────────────────────────────────────────
# Base URL used in email links, webhooks, and self-referential API calls.
# In Vercel this is automatically set via VERCEL_URL, but override here
# if you need a canonical custom domain (e.g., https://grenbee.com).
APP_URL="https://grenbee.com"
