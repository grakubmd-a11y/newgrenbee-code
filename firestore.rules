rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Default catch-all deny rule for secure-by-default
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.admin == true ||
        (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin"
        )
      );
    }

    function isAdminOrManager() {
      return isAdmin() || (
        isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ["admin", "manager"]
      );
    }

    // Validation blueprints for entities

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'name', 'email'])
        && data.uid is string && data.uid.size() <= 128
        && data.name is string && data.name.size() <= 100
        && data.email is string && data.email.size() <= 100
        && (!('role' in data) || (data.role is string && data.role in ['admin', 'manager', 'staff', 'customer']))
        && (!('phone' in data) || (data.phone is string && data.phone.size() <= 30))
        && (!('address' in data) || (data.address is string && data.address.size() <= 200))
        && (!('activeMembership' in data) || (data.activeMembership is string && data.activeMembership.size() <= 50))
        && (!('petsStatus' in data) || (data.petsStatus is string && data.petsStatus.size() <= 50))
        && (!('keyPreferences' in data) || (data.keyPreferences is string && data.keyPreferences.size() <= 50))
        && (!('lockboxCode' in data) || (data.lockboxCode is string && data.lockboxCode.size() <= 30))
        && (!('specialNote' in data) || (data.specialNote is string && data.specialNote.size() <= 1000))
        && (!('cardName' in data) || (data.cardName is string && data.cardName.size() <= 100))
        && (!('cardNumber' in data) || (data.cardNumber is string && data.cardNumber.size() <= 40))
        && (!('cardExpiry' in data) || (data.cardExpiry is string && data.cardExpiry.size() <= 10))
        && (!('cardProvider' in data) || (data.cardProvider is string && data.cardProvider.size() <= 20));
    }

    function isValidBooking(data) {
      return data.keys().hasAll(['id', 'serviceId', 'serviceName', 'bookingDate', 'timeSlot', 'status', 'customerName', 'email', 'phone', 'address', 'units', 'frequency', 'totalCost', 'createdAt'])
        && data.id is string && data.id.size() <= 128
        && data.serviceId is string && data.serviceId.size() <= 128
        && data.serviceName is string && data.serviceName.size() <= 100
        && data.bookingDate is string && data.bookingDate.size() <= 30
        && data.timeSlot is string && data.timeSlot.size() <= 50
        && data.status is string && data.status.size() <= 30 && data.status in ['scheduled', 'dispatched', 'in-progress', 'completed', 'cancelled']
        && data.customerName is string && data.customerName.size() <= 100
        && data.email is string && data.email.size() <= 100
        && data.phone is string && data.phone.size() <= 30
        && data.address is string && data.address.size() <= 200
        && data.units is number && data.units >= 0 && data.units <= 100000
        && data.frequency is string && data.frequency.size() <= 30
        && data.totalCost is number && data.totalCost >= 0
        && data.createdAt is string && data.createdAt.size() <= 40
        && (!('userId' in data) || (data.userId is string && data.userId.size() <= 128))
        && (!('paymentMethod' in data) || (data.paymentMethod is string && data.paymentMethod.size() <= 30))
        && (!('paymentStatus' in data) || (data.paymentStatus is string && data.paymentStatus.size() <= 30))
        && (!('stripePaymentIntentId' in data) || (data.stripePaymentIntentId is string && data.stripePaymentIntentId.size() <= 128))
        && (!('stripePaymentStatus' in data) || (data.stripePaymentStatus is string && data.stripePaymentStatus.size() <= 40))
        && (!('originalCost' in data) || (data.originalCost is number && data.originalCost >= 0))
        && (!('couponCode' in data) || (data.couponCode is string && data.couponCode.size() <= 40))
        && (!('couponDiscount' in data) || (data.couponDiscount is number && data.couponDiscount >= 0))
        && (!('notes' in data) || (data.notes is string && data.notes.size() <= 2000));
    }

    function isValidReview(data) {
      return data.keys().hasAll(['id', 'serviceId', 'authorName', 'rating', 'comment', 'date', 'helpfulCount', 'verified'])
        && data.id is string && data.id.size() <= 128
        && data.serviceId is string && data.serviceId.size() <= 128
        && data.authorName is string && data.authorName.size() <= 100
        && data.rating is number && data.rating >= 1 && data.rating <= 5
        && data.comment is string && data.comment.size() <= 2000
        && data.date is string && data.date.size() <= 30
        && data.helpfulCount is number && data.helpfulCount >= 0
        && data.verified is bool;
    }

    function isValidService(data) {
      return data.keys().hasAll(['id', 'name', 'basePrice'])
        && data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() <= 100
        && data.basePrice is number && data.basePrice >= 0;
    }

    function isValidStaff(data) {
      return data.keys().hasAll(['id', 'name', 'email', 'active'])
        && data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() <= 100
        && data.email is string && data.email.size() <= 100
        && data.active is bool;
    }

    function isValidCoverage(data) {
      return data.keys().hasAll(['zipCode', 'city', 'state', 'active'])
        && data.zipCode is string && data.zipCode.size() <= 20
        && data.city is string && data.city.size() <= 100
        && data.state is string && data.state.size() <= 100
        && data.active is bool;
    }

    function isValidSettings(data) {
      return data.keys().hasAll(['id', 'name', 'bookingEnabled'])
        && data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() <= 100
        && data.bookingEnabled is bool
        && (!('phone' in data) || (data.phone is string && data.phone.size() <= 30))
        && (!('email' in data) || (data.email is string && data.email.size() <= 100))
        && (!('timezone' in data) || (data.timezone is string && data.timezone.size() <= 80))
        && (!('stripeMode' in data) || (data.stripeMode is string && data.stripeMode in ['test', 'live']))
        && (!('stripePublishableKey' in data) || (data.stripePublishableKey is string && data.stripePublishableKey.size() <= 200))
        && (!('googleMapsEnabled' in data) || data.googleMapsEnabled is bool)
        && (!('googleMapsApiKey' in data) || (data.googleMapsApiKey is string && data.googleMapsApiKey.size() <= 200))
        && (!('googleMapsAutocompleteEnabled' in data) || data.googleMapsAutocompleteEnabled is bool)
        && (!('googleAuthEnabled' in data) || data.googleAuthEnabled is bool);
    }

    function isValidActivity(data) {
      return data.keys().hasAll(['id', 'type', 'entityType', 'entityId', 'title', 'detail', 'actorName', 'actorEmail', 'severity', 'createdAt'])
        && data.id is string && data.id.size() <= 128
        && data.type is string && data.type.size() <= 80
        && data.entityType is string && data.entityType in ['booking', 'service', 'staff', 'coverage', 'review', 'settings', 'coupon', 'system']
        && data.entityId is string && data.entityId.size() <= 128
        && data.title is string && data.title.size() <= 160
        && data.detail is string && data.detail.size() <= 1000
        && data.actorName is string && data.actorName.size() <= 120
        && data.actorEmail is string && data.actorEmail.size() <= 160
        && data.severity is string && data.severity in ['info', 'success', 'warning', 'error']
        && data.createdAt is string && data.createdAt.size() <= 40;
    }

    function isValidCoupon(data) {
      return data.keys().hasAll(['id', 'code', 'enabled', 'discountType', 'value', 'minimumOrderTotal', 'usageLimit', 'usedCount', 'serviceIds', 'startsAt', 'expiresAt', 'createdAt', 'updatedAt'])
        && data.id is string && data.id.size() <= 128
        && data.code is string && data.code.size() >= 2 && data.code.size() <= 40
        && data.enabled is bool
        && data.discountType is string && data.discountType in ['percent', 'fixed']
        && data.value is number && data.value >= 0 && data.value <= 100000
        && data.minimumOrderTotal is number && data.minimumOrderTotal >= 0
        && data.usageLimit is number && data.usageLimit >= 0
        && data.usedCount is number && data.usedCount >= 0
        && data.serviceIds is list && data.serviceIds.size() <= 100
        && data.startsAt is string && data.startsAt.size() <= 40
        && data.expiresAt is string && data.expiresAt.size() <= 40
        && data.createdAt is string && data.createdAt.size() <= 40
        && data.updatedAt is string && data.updatedAt.size() <= 40;
    }

    // Collection: Users
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow create: if isValidUser(incoming()) && (
        isAdmin() ||
        (isOwner(userId) && (!('role' in incoming()) || incoming().role == "customer"))
      );
      allow list: if isAdminOrManager();
      allow update: if (isOwner(userId) || isAdmin()) && isValidUser(incoming()) && (
        isAdmin() ||
        incoming().diff(existing()).affectedKeys().hasOnly([
          'name', 'phone', 'address', 'activeMembership', 'petsStatus', 
          'keyPreferences', 'lockboxCode', 'specialNote', 'cardName', 
          'cardNumber', 'cardExpiry', 'cardProvider', 'updatedAt'
        ])
      );
      allow delete: if isAdmin();
    }

    // Collection: Bookings
    match /bookings/{bookingId} {
      allow get: if isSignedIn() && isValidId(bookingId) && (
        ( 'userId' in existing() && existing().userId == request.auth.uid ) ||
        ( existing().email == request.auth.token.email ) ||
        isAdminOrManager()
      );
      
      allow list: if isSignedIn() && (
        ( resource.data.userId == request.auth.uid ) ||
        ( resource.data.email == request.auth.token.email ) ||
        isAdminOrManager()
      );

      allow create: if isSignedIn() && isValidId(bookingId) && isValidBooking(incoming()) && (
        incoming().userId == request.auth.uid ||
        incoming().email == request.auth.token.email ||
        isAdminOrManager()
      );

      allow update: if isSignedIn() && isValidId(bookingId) && isValidBooking(incoming()) && (
        isAdminOrManager() || (
          ( ( 'userId' in existing() && existing().userId == request.auth.uid ) ||
            ( existing().email == request.auth.token.email ) ) && (
            incoming().diff(existing()).affectedKeys().hasOnly([
              'status', 'bookingDate', 'timeSlot', 'paymentMethod', 'paymentStatus'
            ])
          )
        )
      );

      allow delete: if isAdmin();
    }

    // Collection: Reviews
    match /reviews/{reviewId} {
      allow read: if true; // Everyone can read reviews
      
      allow create: if isSignedIn() && isValidId(reviewId) && isValidReview(incoming());
      
      allow update: if isSignedIn() && isValidId(reviewId) && isValidReview(incoming()) && (
        // Users can only increment helpfulCount
        incoming().diff(existing()).affectedKeys().hasOnly(['helpfulCount'])
      );
      
      allow delete: if isSignedIn() && isAdminOrManager();
    }

    // Collection: Services
    match /services/{serviceId} {
      allow read: if true; // Public access for estimate calculations
      allow create, update: if isAdminOrManager() && isValidId(serviceId) && isValidService(incoming());
      allow delete: if isAdminOrManager() && isValidId(serviceId);
    }

    // Collection: Staff
    match /staff/{staffId} {
      allow read: if isSignedIn(); // Logged-in users can view dispatch information
      allow create, update: if isAdminOrManager() && isValidId(staffId) && isValidStaff(incoming());
      allow delete: if isAdminOrManager() && isValidId(staffId);
    }

    // Collection: Coverage
    match /coverage/{zipCode} {
      allow read: if true; // Public check for operational bounds
      allow create, update: if isAdminOrManager() && isValidId(zipCode) && isValidCoverage(incoming());
      allow delete: if isAdminOrManager() && isValidId(zipCode);
    }

    // Collection: Settings
    match /settings/{settingsId} {
      allow read: if true; // General app parameters
      allow write: if isAdminOrManager() && isValidId(settingsId) && isValidSettings(incoming());
    }

    // Collection: Admin Activity
    match /activity/{eventId} {
      allow read: if isAdminOrManager();
      allow create, update: if isAdminOrManager() && isValidId(eventId) && isValidActivity(incoming());
      allow delete: if isAdmin();
    }

    // Collection: Recurring Plans
    // Writes go through the server API (Firebase Admin SDK) — no direct client writes.
    match /recurringPlans/{planId} {
      // Owner can read their own plans; admin/manager can read all
      allow get: if isSignedIn() && (
        resource.data.userId == request.auth.uid || isAdminOrManager()
      );
      allow list: if isSignedIn() && (
        resource.data.userId == request.auth.uid || isAdminOrManager()
      );
      // All writes go through the server API (Firebase Admin bypasses these rules)
      allow create, update, delete: if isAdmin();
    }

    // Collection: Membership Plans
    match /membershipPlans/{planId} {
      allow read: if true; // Public — needed to render /plans page
      allow create, update: if isAdminOrManager() && isValidId(planId);
      allow delete: if isAdminOrManager() && isValidId(planId);
    }

    // Collection: Membership Config (yard size guide, etc.)
    match /membershipConfig/{docId} {
      allow read: if true;
      allow write: if isAdminOrManager();
    }

    // Collection: Media Library
    match /media/{mediaId} {
      allow read: if true;  // Public — photos are shown on landing pages
      allow create, update: if isAdminOrManager() && isValidId(mediaId);
      allow delete: if isAdminOrManager() && isValidId(mediaId);
    }

    // Collection: Area Landing Page Content
    match /areaContent/{areaId} {
      allow read: if true;  // Public — needed to render /areas/:slug
      allow create, update: if isAdminOrManager() && isValidId(areaId);
      allow delete: if isAdminOrManager() && isValidId(areaId);
    }

    // Collection: Page CMS Content (home, faq, contact)
    match /pageContent/{pageId} {
      allow read: if true;  // Public — consumed by marketing pages at runtime
      allow write: if isAdminOrManager() && isValidId(pageId);
    }

    // Collection: Contact Form Submissions
    match /contactSubmissions/{submissionId} {
      allow read: if isAdminOrManager();
      allow create: if true;   // Anyone can submit the public contact form
      allow update, delete: if isAdminOrManager();
    }

    // Collection: Coupons
    // Public users can get a single coupon by ID (code validation & enabled check
    // is handled client-side in fetchPublicCouponByCode). Listing all coupons
    // is restricted to admins/managers.
    match /coupons/{couponId} {
      allow get: if isAdminOrManager() || isValidId(couponId);
      allow list: if isAdminOrManager();
      allow create, update: if isAdminOrManager() && isValidId(couponId) && isValidCoupon(incoming());
      allow delete: if isAdminOrManager() && isValidId(couponId);
    }
  }
}
