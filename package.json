{
  "name": "grenbee",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=@grenbee/web",
    "dev:app": "turbo dev --filter=@grenbee/app",
    "build": "turbo build",
    "build:web": "turbo build --filter=@grenbee/web",
    "build:app": "turbo build --filter=@grenbee/app",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "admin:grant": "node ./scripts/grant-admin-role.mjs",
    "rules:deploy": "node ./scripts/deploy-firestore-rules.mjs"
  },
  "devDependencies": {
    "turbo": "^2.5.4",
    "typescript": "~5.8.2"
  },
  "dependencies": {
    "@grenbee/config": "^0.0.0",
    "@grenbee/firebase": "^0.0.0",
    "@grenbee/types": "^0.0.0",
    "firebase-admin": "^13.10.0",
    "lucide-react": "^1.17.0",
    "react": "^19.2.6",
    "react-i18next": "^17.0.8"
  },
  "packageManager": "npm@10.9.2"
}
