rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ── Job photos ───────────────────────────────────────────────────────────
    // Authenticated users can upload; anyone authenticated can read.
    // Fine-grained staff-only restriction is enforced server-side by save-job-photo.js.
    match /jobs/{bookingId}/{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024  // 10 MB max
                   && request.resource.contentType.matches('image/.*');
    }

    // ── Media library (admin-uploaded photos for landing pages) ─────────────
    // Public read so area landing pages can show photos without auth.
    // Write only for authenticated users (admin flow enforces role client-side).
    match /media/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 20 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // ── Deny everything else ─────────────────────────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
